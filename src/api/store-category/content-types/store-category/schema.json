{
  "kind": "collectionType",
  "collectionName": "store_categories",
  "info": {
    "singularName": "store-category",
    "pluralName": "store-categories",
    "displayName": "store-category"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "cover": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "regex": "^https:\\/\\/([a-zA-Z0-9-]+\\.)*(cloudinary\\.com)(\\/.*)?$"
    },
    "name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "maxLength": 100,
      "required": true,
      "regex": "^[A-Za-zÁÉÍÓÚáéíóúÑñ0-9 ]+$"
    },
    "description": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "maxLength": 225,
      "required": true,
      "regex": "^[A-Za-zÁÉÍÓÚáéíóúÑñ0-9., ]+$"
    },
    "is_active": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": true
    }
  }
}

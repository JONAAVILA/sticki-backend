{
  "kind": "collectionType",
  "collectionName": "location_users",
  "info": {
    "singularName": "location-user",
    "pluralName": "location-users",
    "displayName": "location-user"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "street": {
      "type": "string",
      "required": true,
      "regex": "^[a-zA-Z0-9찼챕챠처첬횁횋횒횙횣체횥챰횗.,\\s]+$"
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "location_users"
    },
    "region": {
      "type": "string",
      "required": true,
      "regex": "^[a-zA-Z0-9찼챕챠처첬횁횋횒횙횣체횥챰횗.,\\s]+$"
    },
    "place": {
      "type": "string",
      "required": true,
      "regex": "^[a-zA-Z0-9찼챕챠처첬횁횋횒횙횣체횥챰횗.,\\s]+$"
    },
    "zipCode": {
      "type": "string",
      "minLength": 4,
      "maxLength": 10,
      "required": true
    },
    "country": {
      "type": "string",
      "maxLength": 50,
      "required": true,
      "regex": "^[a-zA-Z0-9찼챕챠처첬횁횋횒횙횣체횥챰횗.,\\s]+$"
    },
    "door": {
      "type": "string",
      "minLength": 1,
      "required": false
    },
    "floor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 3
    },
    "number": {
      "type": "string",
      "maxLength": 6,
      "required": true
    },
    "lat": {
      "type": "decimal",
      "required": true
    },
    "long": {
      "type": "decimal",
      "required": true
    },
    "typeAddress": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "residential",
        "labor"
      ]
    },
    "instructions": {
      "type": "text",
      "maxLength": 200,
      "required": true,
      "regex": "^[a-zA-Z0-9찼챕챠처첬횁횋횒횙횣챰횗체횥\\s,.\\-#]+$"
    }
  }
}

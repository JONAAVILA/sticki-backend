{
  "kind": "collectionType",
  "collectionName": "location_users",
  "info": {
    "singularName": "location-user",
    "pluralName": "location-users",
    "displayName": "location-user"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "street": {
      "type": "string",
      "required": true,
      "regex": "^[a-zA-Z0-9찼챕챠처첬횁횋횒횙횣체횥챰횗.,\\s]+$"
    },
    "lat": {
      "type": "decimal",
      "precision": 10,
      "scale": 6,
      "minLength": 4,
      "maxLength": 12,
      "required": true,
      "default": 0
    },
    "long": {
      "type": "decimal",
      "precision": 10,
      "scale": 6,
      "minLength": 4,
      "maxLength": 12,
      "required": true,
      "default": 0
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "location_users"
    },
    "region": {
      "type": "string",
      "required": true,
      "regex": "^[a-zA-Z0-9찼챕챠처첬횁횋횒횙횣체횥챰횗.,\\s]+$"
    },
    "place": {
      "type": "string",
      "required": true,
      "regex": "^[a-zA-Z0-9찼챕챠처첬횁횋횒횙횣체횥챰횗.,\\s]+$"
    },
    "zipCode": {
      "type": "string",
      "minLength": 4,
      "maxLength": 10,
      "required": true
    },
    "country": {
      "type": "string",
      "maxLength": 50,
      "required": true,
      "regex": "^[a-zA-Z0-9찼챕챠처첬횁횋횒횙횣체횥챰횗.,\\s]+$"
    },
    "door": {
      "type": "string",
      "minLength": 1,
      "required": false
    },
    "floor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 3
    },
    "number": {
      "type": "string",
      "maxLength": 6,
      "required": true
    }
  }
}
